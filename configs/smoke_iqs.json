{
  "_comment": "Smoke IQS: model.epsilons lists slack values; CLI runs one artifact bundle per value under simulation.output_dir/eps_<slug>/. Run: python main.py configs/smoke_iqs.json",
  "model": {
    "type": "iqs",
    "n": 20,
    "epsilons": [0.001, 0.0001, 0.00001]
  },
  "arrivals": {
    "type": "iid_bernoulli"
  },
  "policy": {
    "type": "maxweight"
  },
  "simulation": {
    "T": 2000000,
    "seed": 0,
    "num_replications": 100,
    "output_dir": "_runs/smoke_iqs",
    "progress": true,
    "progress_every": 100000
  },
  "recording": {
    "full_state": false,
    "num_paths_to_save": 10
  },
  "metrics": {
    "series": ["totalQ"],
    "downsample": { "K": 1000, "grid": "raw_time" }
  }
}
