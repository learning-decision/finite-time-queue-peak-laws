{
  "_comment": "Smoke parallel_server: L=4 classes, K=4 persistent servers, complete bipartite K_{4,4}, geometric service mu=0.5 (E[D]=2 slots). Uniform lambdas = (1-eps)*mu*K/L = 0.45 at eps=0.1. Verifies end-to-end pipeline. Run: python main.py configs/smoke_parallel_server.json",
  "model": {
    "type": "parallel_server",
    "L": 4,
    "K": 4,
    "edges": [
      [0, 0], [0, 1], [0, 2], [0, 3],
      [1, 0], [1, 1], [1, 2], [1, 3],
      [2, 0], [2, 1], [2, 2], [2, 3],
      [3, 0], [3, 1], [3, 2], [3, 3]
    ],
    "service_time": { "type": "geometric", "mu": 0.5 },
    "epsilon": 0.1
  },
  "arrivals": {
    "type": "bernoulli_customer",
    "lambdas": [0.45, 0.45, 0.45, 0.45]
  },
  "policy": {
    "type": "maxweight"
  },
  "simulation": {
    "T": 50000,
    "seed": 0,
    "num_replications": 10,
    "output_dir": "_runs/smoke_parallel_server",
    "progress": true,
    "progress_every": 10000
  },
  "recording": {
    "full_state": false,
    "num_paths_to_save": 3
  },
  "metrics": {
    "series": ["totalQ"],
    "downsample": { "K": 500, "grid": "raw_time" }
  }
}
